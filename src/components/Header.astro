---
const pathname = new URL(Astro.request.url).pathname;
import {
  FaHouse,
  FaPenToSquare,
  FaFlask,
  FaGraduationCap,
  FaBars,
  FaXmark,
} from "react-icons/fa6";

const navLinks = [
  { name: "Home", url: "/", icon: FaHouse },
  { name: "Blog", url: "/posts", icon: FaPenToSquare },
  { name: "Lab", url: "/lab", icon: FaFlask },
];
---

<header
  class="fixed top-0 left-0 right-0 z-[1000] bg-bg-1/80 backdrop-blur-md border-b border-bg-2 transition-all duration-300"
>
  <div
    class="max-w-[1200px] mx-auto px-6 py-4 flex items-center justify-between"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group no-underline z-50">
      <div class="relative flex items-center justify-center">
        <div
          class="absolute inset-0 bg-blue-accent/50 blur-md rounded-full group-hover:bg-blue-accent/80 transition-colors duration-300"
        >
        </div>
        <img
          src="https://github.com/f3l1p3v4.png"
          alt="Felipe Valdez"
          class="relative w-10 h-10 md:w-11 md:h-11 rounded-full border-2 border-blue-accent object-cover z-10"
        />
      </div>
      <h1 class="text-blue-accent text-2xl font-bold">
        {"{"}F<span class="text-white">V{"}"}</span>
      </h1>
    </a>

    <!-- Navegação Desktop -->
    <nav class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => {
          const isActive =
            pathname === link.url ||
            (link.url !== "/" && pathname.startsWith(link.url));
          const Icon = link.icon;
          return (
            <a
              href={link.url}
              class={`text-sm font-medium transition-colors hover:text-blue-accent flex items-center gap-2 ${
                isActive ? "text-blue-accent" : "text-text-2"
              }`}
            >
              <Icon /> {link.name}
            </a>
          );
        })
      }
    </nav>

    <!-- Botão Contato (Let's Talk) -->
    <a
      onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})"
      target="_blank"
      rel="noreferrer"
      class="hidden md:flex bg-blue-accent text-bg-1 font-bold text-sm px-5 py-2 rounded-full hover:opacity-80 transition-opacity no-underline cursor-pointer"
    >
      Entrar em Contato
    </a>

    <!-- Menu Mobile Toggle -->
    <div class="md:hidden flex items-center z-50">
      <button
        id="mobile-menu-btn"
        class="text-text-1 hover:text-blue-accent transition-colors p-2"
        aria-label="Abrir Menu"
      >
        <FaBars size={24} />
      </button>
    </div>
  </div>
</header>

<!-- Menu Mobile Overlay (fora do header para escapar do stacking context) -->
<div
  id="mobile-menu"
  class="fixed inset-0 bg-bg-1 z-[2000] translate-x-full transition-transform duration-300 flex flex-col items-center justify-center px-6 md:hidden"
>
  <button
    id="mobile-close-btn"
    class="absolute top-6 right-6 text-text-1 hover:text-blue-accent transition-colors p-2"
    aria-label="Fechar Menu"
  >
    <FaXmark size={32} />
  </button>

  <nav
    class="flex flex-col items-center justify-center gap-6 text-xl w-full max-w-xs"
  >
    {
      navLinks.map((link) => {
        const isActive =
          pathname === link.url ||
          (link.url !== "/" && pathname.startsWith(link.url));
        const Icon = link.icon;
        return (
          <a
            href={link.url}
            class={`font-medium transition-colors hover:text-blue-accent flex items-center gap-4 py-3 border-b border-bg-2/50 ${
              isActive ? "text-blue-accent" : "text-text-2"
            }`}
          >
            <Icon size={24} /> {link.name}
          </a>
        );
      })
    }
    <a
      onclick="document.getElementById('mobile-menu').classList.add('translate-x-full'); document.getElementById('contact').scrollIntoView({behavior:'smooth'})"
      class="bg-blue-accent text-bg-1 font-bold text-center px-6 py-4 rounded-full mt-4 cursor-pointer"
    >
      Entrar em Contato
    </a>
  </nav>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const menuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const closeBtn = document.getElementById("mobile-close-btn");

    if (menuBtn && mobileMenu && closeBtn) {
      menuBtn.addEventListener("click", () => {
        mobileMenu.classList.remove("translate-x-full");
      });

      closeBtn.addEventListener("click", () => {
        mobileMenu.classList.add("translate-x-full");
      });
    }
  });
</script>
