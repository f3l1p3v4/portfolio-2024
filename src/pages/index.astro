    </div>
    </div>
  </section>

  <!-- Process Section -->
  <section id="process" class="py-32 bg-bg-2/20 border-y border-bg-2/50">
    <div class="max-w-[1200px] mx-auto px-6 flex flex-col md:flex-row gap-16">
      <div class="w-full md:w-1/3 animate-on-scroll">
        <h2 class="text-[2.5rem] md:text-[3.5rem] font-bold text-text-1 leading-tight">Como eu <span class="text-blue-accent">trabalho.</span></h2>
        <p class="text-text-2 mt-6 text-xl leading-relaxed">Um fluxo otimizado para entregar o máximo de valor com eficiência e transparência.</p>
      </div>
      <div class="w-full md:w-2/3 flex flex-col gap-12">
        {processSteps.map((step, idx) => (
          <div class={`flex gap-8 animate-on-scroll delay-${(idx + 1) * 100}`}>
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-blue-accent/10 border-2 border-blue-accent flex items-center justify-center text-blue-accent font-black text-2xl shadow-[0_0_15px_rgba(163,234,42,0.2)]">
              {idx + 1}
            </div>
            <div>
              <h3 class="text-2xl font-bold text-text-1 mb-4">{step.title}</h3>
              <p class="text-text-2 text-sm leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <Testimonials client:visible />

  <!-- Contact/CTA Section -->
  <section id="contact" class="py-24 bg-blue-accent text-bg-1 relative overflow-hidden border-t-4 border-blue-accent">
    <div class="max-w-[1200px] mx-auto px-6 relative z-10 flex flex-col md:flex-row items-center justify-between gap-16">
      
      <div class="animate-on-scroll w-full md:w-1/2">
        <Typewriter text="contato" className="text-bg-1 font-mono text-sm mb-4 font-bold" dotClass="bg-bg-1" />
        <h2 class="text-bg-1 text-[4rem] md:text-[5rem] font-bold mb-8 leading-[1.1] tracking-tight">Pronto para <br/>construir?</h2>
        <p class="text-bg-1 text-xl font-medium max-w-lg opacity-90 mb-4 leading-relaxed">Vamos transformar sua ideia em uma aplicação incrível. Preencha os dados e vamos conversar.</p>
      </div>

      <div class="animate-on-scroll w-full md:w-1/2 delay-200">
        <form class="bg-bg-1 px-5 py-8 rounded-[1.6rem] text-text-1 flex flex-col gap-5 shadow-2xl relative z-20 border border-bg-2/50">
          <input type="text" id="w-nome" placeholder="Seu nome" class="w-full bg-bg-2 border border-bg-2 rounded-xl px-5 py-4 focus:outline-none focus:border-blue-accent transition-colors font-medium">
          
          <input type="tel" id="w-telefone" placeholder="Seu WhatsApp" class="w-full bg-bg-2 border border-bg-2 rounded-xl px-5 py-4 focus:outline-none focus:border-blue-accent transition-colors font-medium">
          
          <div class="relative">
            <select id="w-servico" class="w-full bg-bg-2 border border-bg-2 rounded-xl px-5 py-4 focus:outline-none focus:border-blue-accent transition-colors text-text-1 font-medium appearance-none">
              <option value="" disabled selected class="text-text-2">Qual serviço você precisa?</option>
              <option value="Criação de Site Institucional">Site Institucional</option>
              <option value="E-commerce / Loja Virtual">E-commerce / Loja Virtual</option>
              <option value="Landing Page de Alta Conversão">Landing Page de Alta Conversão</option>
              <option value="Sistema Web Personalizado">Sistema Web Personalizado</option>
              <option value="Outro">Outro serviço</option>
            </select>
            <div class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none">
              <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>

          <textarea id="w-mensagem" placeholder="Fale um pouco sobre o seu projeto..." rows="4" class="w-full bg-bg-2 border border-bg-2 rounded-xl px-5 py-4 focus:outline-none focus:border-blue-accent transition-colors resize-none font-medium"></textarea>
          
          <button type="button" onclick="sendWhatsApp()" class="w-full bg-blue-accent text-bg-1 font-bold text-lg px-6 py-4 rounded-xl hover:opacity-90 transition-opacity mt-2 shadow-[0_0_20px_rgba(163,234,42,0.3)]">
            Enviar Mensagem
          </button>
        </form>
      </div>
    </div>
    <!-- Background element -->
    <div class="text-[20rem] md:text-[30rem] font-black text-bg-1/10 absolute -right-20 -bottom-32 select-none animate-on-scroll delay-300 pointer-events-none tracking-tighter">
      {"{FV}"}
    </div>
  </section>

  <Footer />
</Layout>

<script is:inline>
  function sendWhatsApp() {
    const nome = document.getElementById('w-nome').value;
    const telefone = document.getElementById('w-telefone').value;
    const servico = document.getElementById('w-servico').value;
    const mensagem = document.getElementById('w-mensagem').value;
    
    if (!nome || !servico) {
      alert("Por favor, preencha pelo menos seu nome e o serviço desejado.");
      return;
    }
    
    const text = `Olá, meu nome é *${nome}*.\nTenho interesse no serviço: *${servico}*.\n\n${mensagem}`;
    const encodedText = encodeURIComponent(text);
    window.open(`https://wa.me/5567992656801?text=${encodedText}`, '_blank');
  }
</script>
