              <div class="w-2 h-2 rounded-full bg-blue-accent shadow-[0_0_8px_#a3ea2a]"></div> <span>React</span>
            </div>
            <div class="flex items-center gap-2 rounded-full px-4 md:px-5 py-2 md:py-2.5 bg-transparent text-text-2/60 font-mono text-[10px] md:text-xs">
              <div class="w-1.5 h-1.5 rounded-full bg-text-2/30"></div> <span>Next.js</span>
