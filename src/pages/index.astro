---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroImage from '../components/HeroImage.astro';
import Testimonials from '../components/Testimonials';
import Typewriter from '../components/Typewriter.astro';
import { FaLayerGroup, FaCode, FaDatabase, FaBolt, FaTerminal, FaGithub, FaLinkedin } from "react-icons/fa6";

const projects = [
    {
      id: 1,
      image: '/projects/img-01.png',
      title: 'Focus',
      description: 'Trata-se de um to to list integrado com o pomodoro, onde pode criar tarefas com timer de pomodoro ou editavel, marcar como concluídas e deletar.',
      link: 'https://focus.felipevaldez.com.br',
      skills: 'react, typescript, docker, node, postgres',
      reference: 'Felipe Valdez'
    },
    {
      id: 4,
      image: '/projects/img-04.png',
      title: 'DT Money',
      description: 'A ideia deste projeto é criar um controle financeiro para o usuário. Nele o usuário pode adicionar as entradas e saídas financeiras do seu dia-a-dia.',
      link: 'https://ignite-react-03-dt-money.vercel.app',
      skills: 'reactjs, typescript, vite, styled-components, date-fns, zod',
      reference: 'Rocketseat'
    },
];

const skills = ["HTML", "CSS", "JavaScript", "TypeScript", "React", "Next.js", "Astro", "Tailwind CSS", "Node.js", "NestJS", "PostgreSQL", "MySQL", "MongoDB", "Docker"];

const processSteps = [
  { title: "Descoberta & Planejamento", desc: "Entendemos a fundo a necessidade do projeto para alinhar expectativas e arquitetura." },
  { title: "Desenvolvimento Ágil", desc: "Código limpo e escalável utilizando as tecnologias mais modernas do mercado." },
  { title: "Lançamento & Manutenção", desc: "Deploy otimizado e acompanhamento contínuo para garantir estabilidade." }
];

const portfolioProjects = [
  { id: 1, type: "Site Institucional", title: "Rengetec Engenharia", desc: "Site corporativo otimizado para SEO com apresentação de serviços e portfólio de obras.", skills: "Gatsby, CSS", url: "rengetec.com.br/", image: "/images/projects/1.jpg", year: "2018" },
  { id: 2, type: "Site Institucional", title: "MSC Telecomunicações", desc: "Site corporativo com apresentação de serviços de telecomunicações.", skills: "Gatsby, CSS", url: "msctelecomunicacoes.com.br/", image: "/images/projects/2.jpg", year: "2019" },
  { id: 3, type: "Site Institucional", title: "Vop Segurança", desc: "Site corporativo com apresentação de serviços relacionados à segurança.", skills: "React, CSS", url: "vopseguranca.com.br/", image: "/images/projects/3.jpg", year: "2019" },
  { id: 4, type: "Blog", title: "Blog Devload", desc: "Portal de notícias de tecnologia focado em velocidade de carregamento e experiência do leitor.", skills: "Gatsby, Netlify CMS", url: "blog.devload.com.br/", image: "/images/projects/4.jpg", year: "2020" },
  { id: 5, type: "Landing Page", title: "LP Dra. Bianca", desc: "Landing Page focada em conversão de leads.", skills: "Astro, Tailwind CSS", url: "drabiancadias.com.br/", image: "/images/projects/5.png", year: "2022" },
  { id: 6, type: "E-commerce", title: "Bela Bagunça", desc: "Plataforma de e-commerce para venda de roupas infantis.", skills: "Next.js, Tailwind CSS, Stripe", url: "belabagunca.com.br/", image: "/images/projects/6.png", year: "2023" },
  { id: 7, type: "Sistema", title: "MusicosOn", desc: "Sistema de gerenciamento de estudos e controle de desempenho dos alunos.", skills: "React, Tailwind CSS, Node.js, PostgreSQL, Docker", url: "musicason.com.br/", image: "/images/projects/7.png", year: "2025" }
];
---

<Layout title="Felipe Valdez | Web Developer">
  <Header />

  <!-- Hero Section -->
  <section id="home" class="min-h-[100dvh] pt-32 pb-12 flex flex-col-reverse md:flex-row items-center justify-between max-w-[1200px] mx-auto px-6 gap-12">
    <div class="flex-1 text-left animate-on-scroll">
      <h1 class="text-[3rem] md:text-[4.5rem] font-bold text-text-1 leading-[1.1] mb-6 tracking-tight">
        Construo aplicações que <br/><span class="text-blue-accent">movem</span> o futuro.
      </h1>
      <p class="text-text-2 text-lg md:text-xl mb-10 max-w-lg leading-relaxed">
        Especialista em desenvolvimento de software focado em criar soluções digitais modernas, velozes e escaláveis que geram resultados reais para o seu negócio.
      </p>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a href="#projects" class="bg-blue-accent text-bg-1 font-bold px-8 py-4 rounded-full hover:opacity-80 transition-opacity no-underline w-full sm:w-auto text-center">
          Ver meus projetos
        </a>
        <a onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})" target="_blank" rel="noreferrer" class="cursor-pointer text-text-1 font-bold px-8 py-4 rounded-full border-2 border-text-1 hover:bg-text-1 hover:text-bg-1 transition-colors no-underline w-full sm:w-auto text-center">
          Enviar mensagem
        </a>
      </div>
    </div>
    <div class="flex-1 w-full flex items-center justify-center animate-on-scroll delay-200">
      <HeroImage />
    </div>
  </section>

  <!-- About & Stats Section -->
  <section id="about" class="py-32 bg-bg-2/20 border-b border-bg-2/50 relative">
    <div class="max-w-[1200px] mx-auto px-6 flex flex-col md:flex-row items-center gap-16">
      <div class="w-full md:w-1/3 animate-on-scroll relative">
        <div class="absolute inset-0 bg-blue-accent/20 blur-3xl rounded-full"></div>
        <img src="https://github.com/f3l1p3v4.png" alt="Felipe Valdez" class="relative w-full aspect-square object-cover rounded-3xl transition-all duration-700 shadow-2xl border border-bg-2" />
      </div>
      <div class="w-full md:w-2/3 animate-on-scroll delay-200">
        <Typewriter text="sobre mim" className="text-blue-accent font-mono text-sm mb-4" />
        <h2 class="text-[2.5rem] md:text-[3.5rem] font-bold text-text-1 mb-8 leading-tight">
          Olá, eu sou <span class="text-blue-accent">Felipe Valdez</span>
        </h2>
        <p class="text-text-2 text-xl mb-6 leading-relaxed max-w-2xl">
          Minha jornada na tecnologia começou em 2016. Sou apaixonado por arquitetura de software, otimização de performance e construção de interfaces intuitivas. Atuo tanto no Frontend quanto no Backend para garantir a excelência da aplicação de ponta a ponta.
        </p>
        
        <div class="flex gap-4 mb-10">
          <a href="https://github.com/f3l1p3v4" target="_blank" rel="noreferrer" class="text-blue-accent hover:opacity-50 transition-colors text-3xl" aria-label="GitHub">
            <FaGithub />
          </a>
          <a href="https://linkedin.com/in/lipe-dev" target="_blank" rel="noreferrer" class="text-blue-accent hover:opacity-50 transition-colors text-3xl" aria-label="LinkedIn">
            <FaLinkedin />
          </a>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 gap-8 py-8 border-y border-bg-2/50">
          <div>
            <h4 class="text-5xl md:text-6xl font-bold text-text-1 mb-2">5<span class="text-blue-accent">+</span></h4>
            <p class="text-text-2 text-sm uppercase tracking-widest font-bold">Anos de XP</p>
          </div>
          <div class="col-span-2 md:col-span-1">
            <h4 class="text-5xl md:text-6xl font-bold text-text-1 mb-2">100<span class="text-blue-accent">%</span></h4>
            <p class="text-text-2 text-sm uppercase tracking-widest font-bold">Comprometimento</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-32 max-w-[1200px] mx-auto px-6 relative overflow-hidden">
    <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
      
      <!-- Left Content -->
      <div class="w-full md:w-2/5 animate-on-scroll shrink-0 pr-0 md:pr-4">
        <Typewriter text="projetos" className="text-blue-accent font-mono text-sm mb-4" />
        <h2 class="text-[3rem] md:text-[4rem] font-bold text-text-1 leading-[1.1] mb-6 tracking-tight">
          Projetos <span class="text-blue-accent">em Destaque</span>
        </h2>
        <p class="text-text-2 text-lg leading-relaxed opacity-90">
          Separei aqui alguns dos meus melhores projetos para demonstrar a qualidade, a robustez e a dedicação que aplico em cada solução que desenvolvo de ponta a ponta.
        </p>
      </div>

      <!-- Right Carousel -->
      <div class="w-full md:w-3/5 relative animate-on-scroll delay-200">
        <!-- Fade edges (mask-image) -->
        <div 
          class="flex overflow-hidden w-full relative" 
          style="mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);"
        >
          <div class="flex flex-nowrap gap-4 md:gap-6 animate-marquee w-max shrink-0 items-start pr-4 md:pr-6">
            {portfolioProjects.map((project, index) => (
              <div class="w-[240px] md:w-[260px] shrink-0 group cursor-pointer">
                <!-- Image Container (Browser Mockup) -->
                <div class="rounded-t-2xl border border-bg-2/50 bg-bg-1 overflow-hidden shadow-2xl relative aspect-[4/3] flex flex-col mb-6">
                  <!-- Browser Top Bar -->
                  <div class="h-6 md:h-8 bg-bg-2/40 border-b border-bg-2/50 flex items-center px-4 shrink-0 relative">
                    <div class="mx-auto flex items-center gap-2">
                      <div class="w-1.5 h-1.5 rounded-full bg-blue-accent/50 group-hover:bg-blue-accent transition-colors duration-500"></div>
                      <span class="text-[9px] md:text-[10px] text-text-2/40 font-mono tracking-wider group-hover:text-text-2/80 transition-colors duration-500">{project.url}</span>
                    </div>
                  </div>
                  <!-- Image -->
                  <div class="relative flex-1 overflow-hidden">
                    <img src={project.image} alt={project.title} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" />
                    <div class="absolute inset-0 bg-bg-1/10 group-hover:bg-transparent transition-colors duration-500 pointer-events-none"></div>
                  </div>
                </div>
                
                <!-- Content Below -->
                <div class="flex flex-col">
                  <p class="text-blue-accent font-mono text-xs mb-3 tracking-wider font-semibold">
                    0{index + 1} / {project.type} · {project.year}
                  </p>
                  <h3 class="text-lg md:text-xl font-bold text-text-1 mb-2 group-hover:text-blue-accent transition-colors duration-300 tracking-tight">{project.title}</h3>
                  <p class="text-text-2 text-xs md:text-sm leading-relaxed mb-4 opacity-90">{project.desc}</p>
                  
                  <div class="flex flex-wrap gap-1.5 mt-auto">
                    {project.skills.split(',').map(skill => (
                      <span class="text-[10px] md:text-xs font-mono text-text-2/80 bg-transparent border border-text-2/30 px-2.5 py-1 rounded-full uppercase tracking-wider">{skill.trim()}</span>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
          <!-- Duplicate for seamless loop -->
          <div class="flex flex-nowrap gap-4 md:gap-6 animate-marquee w-max shrink-0 items-start pr-4 md:pr-6" aria-hidden="true">
            {portfolioProjects.map((project, index) => (
              <div class="w-[240px] md:w-[260px] shrink-0 group cursor-pointer">
                <!-- Image Container (Browser Mockup) -->
                <div class="rounded-t-2xl border border-bg-2/50 bg-bg-1 overflow-hidden shadow-2xl relative aspect-[4/3] flex flex-col mb-6">
                  <!-- Browser Top Bar -->
                  <div class="h-6 md:h-8 bg-bg-2/40 border-b border-bg-2/50 flex items-center px-4 shrink-0 relative">
                    <div class="mx-auto flex items-center gap-2">
                      <div class="w-1.5 h-1.5 rounded-full bg-blue-accent/50 group-hover:bg-blue-accent transition-colors duration-500"></div>
                      <span class="text-[9px] md:text-[10px] text-text-2/40 font-mono tracking-wider group-hover:text-text-2/80 transition-colors duration-500">{project.url}</span>
                    </div>
                  </div>
                  <!-- Image -->
                  <div class="relative flex-1 overflow-hidden">
                    <img src={project.image} alt={project.title} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" />
                    <div class="absolute inset-0 bg-bg-1/10 group-hover:bg-transparent transition-colors duration-500 pointer-events-none"></div>
                  </div>
                </div>
                
                <!-- Content Below -->
                <div class="flex flex-col">
                  <p class="text-blue-accent font-mono text-xs mb-3 tracking-wider font-semibold">
                    0{index + 1} / {project.type}  · {project.year}
                  </p>
                  <h3 class="text-lg md:text-xl font-bold text-text-1 mb-2 group-hover:text-blue-accent transition-colors duration-300 tracking-tight">{project.title}</h3>
                  <p class="text-text-2 text-xs md:text-sm leading-relaxed mb-4 opacity-90">{project.desc}</p>
                  
                  <div class="flex flex-wrap gap-1.5 mt-auto">
                    {project.skills.split(',').map(skill => (
                      <span class="text-[10px] md:text-xs font-mono text-text-2/80 bg-transparent border border-text-2/30 px-2.5 py-1 rounded-full uppercase tracking-wider">{skill.trim()}</span>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Tools Section -->
  <section id="tools" class="py-26 w-full relative overflow-hidden">
    <div class="absolute -left-10 top-1/2 -translate-y-1/2 w-[300px] h-[300px] bg-blue-accent/10 blur-[120px] rounded-full pointer-events-none -z-10"></div>
    
    <div class="max-w-[1200px] mx-auto px-6 relative">
      <div class="text-center animate-on-scroll mb-16 flex flex-col items-center">
      <Typewriter text="ferramentas" className="text-blue-accent font-mono text-sm mb-4" />
      <h2 class="text-[2.5rem] md:text-[3.5rem] font-bold text-text-1 mb-6 leading-tight">
        As tecnologias por trás das minhas<br />
          <span class="text-blue-accent">soluções.</span>
      </h2>
      <p class="text-text-2 text-lg max-w-2xl mx-auto">Tudo aqui foi escolhido por sua performance, escalabilidade e para entregar código limpo e moderno.</p>
    </div>
    
    <div class="max-w-4xl mx-auto animate-on-scroll delay-200 mt-16">
      <!-- Floating Pills Container with faded edges -->
      <div 
        class="flex flex-col gap-4 relative overflow-hidden pb-12 mb-8" 
        style="mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);"
